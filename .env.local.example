# ── Auth ──────────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=                          # openssl rand -base64 32

GOOGLE_CLIENT_ID=                         # Google Console → APIs & Services → Credentials
GOOGLE_CLIENT_SECRET=                     # Google Console → APIs & Services → Credentials

# ── Database ───────────────────────────────────────────────────────
DATABASE_URL=                             # Railway → твой PostgreSQL → Variables → DATABASE_URL

# ── Telegram Bot ───────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=                       # @BotFather → /newbot или /mybots → токен

# ── Cron Security ──────────────────────────────────────────────────
CRON_SECRET=                              # openssl rand -base64 32
